# MCP Server — environment variable configuration
# Copy to .env and edit: cp .env.example .env

# Workspace directory (container path, maps to host /home/ubuntu/repo)
WORKSPACE_DIR=/workspace

# Command timeout in seconds
COMMAND_TIMEOUT=120

# Allowed file extensions for read_file (comma-separated), leave empty = allow all
# ALLOWED_READ_EXTENSIONS=.py,.txt,.md,.json,.yaml,.yml,.html,.css,.js,.ts,.sh,.toml,.cfg
