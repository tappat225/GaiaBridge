# ============================================================
# MCP Server — Nginx configuration snippet
# Add to the HTTPS server block in /etc/nginx/sites-available/<your-domain>
# ============================================================

# Authentication token mapping
map $http_authorization $mcp_auth_result {
    "Bearer <your-bearer-token>"  "ok";
    default                                                                      "denied";
}

# Token is only checked in the MCP location
# (map goes outside the server block, location goes inside the HTTPS server block)

# ----- Add the following inside the HTTPS server { } block -----

# MCP Server endpoint (protected by Bearer Token)
location /_mcp {
    # Token validation
    if ($mcp_auth_result = "denied") {
        return 401 '{"error":"unauthorized","message":"Valid Bearer token required"}\n';
        add_header Content-Type application/json;
    }

    # Proxy to MCP Server inside Docker container
    proxy_pass http://127.0.0.1:9020/mcp;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # SSE / Streamable HTTP requires disabled buffering
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;

    # Support Upgrade header (for future WebSocket use)
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
}
