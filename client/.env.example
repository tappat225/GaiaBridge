# WorkBridge Client — environment variable configuration
# Copy to .env and fill in real values: cp .env.example .env
# Then source in your shell: source .env

# MCP server URL (Nginx reverse-proxied HTTPS address)
MCP_URL=https://<your-domain>/_mcp

# Bearer Token (must match the token in nginx-mcp.conf)
AUTH_TOKEN=<your-bearer-token>

# Unix socket path (for daemon)
MCP_SOCKET_PATH=/tmp/mcp-daemon.sock

# PID file path (for daemon)
MCP_PID_FILE=/tmp/mcp-daemon.pid
