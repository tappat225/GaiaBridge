# WorkBridge Client — 环境变量配置
# 复制为 .env 后填写真实值: cp .env.example .env
# 然后在 shell 中 source: source .env

# MCP 服务器地址（Nginx 反代后的 HTTPS 地址）
MCP_URL=https://<your-domain>/_mcp

# Bearer Token（与 nginx-mcp.conf 中配置的一致）
AUTH_TOKEN=<your-bearer-token>

# Unix socket 路径（daemon 用）
MCP_SOCKET_PATH=/tmp/mcp-daemon.sock

# PID 文件路径（daemon 用）
MCP_PID_FILE=/tmp/mcp-daemon.pid
